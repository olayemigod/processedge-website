# ProcessEdge Solutions — Environment Variables
# Copy this file to .env.local and fill in actual values before deployment
# NEVER commit .env.local to version control

# Contact form endpoint (Formspree, EmailJS, or custom backend)
VITE_CONTACT_FORM_ENDPOINT=

# Portal domain (override if using a staging environment)
VITE_PORTAL_URL=https://portal.processedge.com.ng

# Analytics (e.g. Google Analytics Measurement ID)
VITE_GA_MEASUREMENT_ID=

# Optional: Meta Pixel ID for Facebook ads
VITE_META_PIXEL_ID=

# Optional: Site canonical URL (e.g. override in staging)
VITE_SITE_URL=https://www.processedge.com.ng

# Optional: ERPNext/Frappe Portal API base (defaults to Portal URL)
VITE_API_BASE_URL=https://portal.processedge.com.ng

# Optional: Business contact email
VITE_BRAND_EMAIL=hello@processedge.com.ng

# Optional: WhatsApp support phone number (digits only, no spaces or +)
VITE_WHATSAPP_NUMBER=2348096086857

